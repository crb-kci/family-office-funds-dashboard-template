# Copy to .env (for local dev) or set these as Cloud Run env vars.
# Do NOT commit .env.

# ── Google OAuth (for sign-in) ─────────────────────────────
# Create these in Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full callback URL. For local: http://localhost:8080/auth/google/callback
# For Cloud Run: https://<your-service>-XXXX.run.app/auth/google/callback
CALLBACK_URL=http://localhost:8080/auth/google/callback

# ── Who can sign in ────────────────────────────────────────
# Use one or both. Domains match by email suffix.
ALLOWED_DOMAINS=yourfamilyoffice.com
# ALLOWED_EMAILS=person@example.com,other@example.com

# ── Google Sheets (data source) ────────────────────────────
# The sheet the dashboard reads from. Share the sheet with the service
# account email (Viewer is enough) before the app can read it.
SPREADSHEET_ID=
# Tab with one row per fund (or per fund × entity). Expected columns:
# Fund Name, Entity, Vintage, Commitment, Called, Distributed, NAV,
# IRR, TVPI, DPI, % Funded.
FUNDS_TAB=Funds
# Tab with the capital-call / distribution ledger. Expected columns:
# Entity, Fund, Date, Type, Amount.
TXNS_TAB=Transactions
# Optional tab mapping fund names to firm/GP names. Columns: Fund Name, Firm.
MAPPING_TAB=Fund Mapping

# Service account key JSON. For local dev, easier to set
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json instead.
# For Cloud Run, paste the entire JSON as the value below (wrap in single quotes).
GOOGLE_SERVICE_ACCOUNT_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ── Session ────────────────────────────────────────────────
# Any random string. Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Branding ───────────────────────────────────────────────
ORG_NAME=Fund Dashboard
ORG_TAGLINE=Family Office LP Commitments
SUPPORT_EMAIL=

# ── Optional: feedback sheet ───────────────────────────────
# If set, the dashboard can POST feedback to a separate Google Sheet.
# FEEDBACK_SHEET_ID=

# ── Runtime ────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
# CACHE_TTL_MS=21600000
